{
    "manifest_version": 3,
    "name": "WordClip",
    "version": "1.0",
    "description": "Highlight any word to see it used in a real Youtube video",
    "permissions": [
        "activeTab",
        "storage",
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "WordClip"
    },
    "background": {
        "service_worker": "background.js"
    },
}
